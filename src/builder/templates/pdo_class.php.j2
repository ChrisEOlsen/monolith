<?php

class {{ pascal_name }} {
    private $pdo;

    public function __construct($pdo) {
        $this->pdo = $pdo;
    }

    public function create($data) {
        $sql = "INSERT INTO {{ plural_name }} ({% for field in fields %}{{ field.name }}{% if not loop.last %}, {% endif %}{% endfor %}) VALUES ({% for field in fields %}:{{ field.name }}{% if not loop.last %}, {% endif %}{% endfor %})";
        $stmt = $this->pdo->prepare($sql);
        
        {% for field in fields %}
        {% if field.name == 'password' %}
        $stmt->bindValue(':{{ field.name }}', password_hash($data['{{ field.name }}'], PASSWORD_DEFAULT));
        {% else %}
        $stmt->bindValue(':{{ field.name }}', $data['{{ field.name }}']);
        {% endif %}
        {% endfor %}
        
        return $stmt->execute();
    }

    public function getAll() {
        $stmt = $this->pdo->query("SELECT * FROM {{ plural_name }}");
        return $stmt->fetchAll(PDO::FETCH_ASSOC);
    }

    public function find($id) {
        $stmt = $this->pdo->prepare("SELECT * FROM {{ plural_name }} WHERE id = :id");
        $stmt->execute(['id' => $id]);
        return $stmt->fetch(PDO::FETCH_ASSOC);
    }
    
    public function delete($id) {
        $stmt = $this->pdo->prepare("DELETE FROM {{ plural_name }} WHERE id = :id");
        return $stmt->execute(['id' => $id]);
    }
}
