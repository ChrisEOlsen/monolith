<?php
/**
 * PAGE: {{ page_name }}
 */
require_once 'db.php';
require_once 'csrf.php';

{% if auth_required %}
// Authentication Check
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

if (!isset($_SESSION['user_id'])) {
    $_SESSION['auth_redirect_to'] = $_SERVER['REQUEST_URI'];
    header("Location: /login.php");
    exit;
}
{% endif %}

// Include requested models
{% if models %}
require_once 'redis.php';
{% endif %}
{% for model in models %}
require_once 'classes/{{ model }}.php';
${{ model | lower }}Model = new {{ model }}($pdo, $redis);
{% endfor %}

// Page Logic
$error = null;
$message = null;

// Handle Actions (Optional)
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!isset($_POST['csrf_token']) || !verify_csrf_token($_POST['csrf_token'])) {
        $error = "Security Error: Invalid CSRF token.";
    } else {
        // Post logic here
    }
}
?>

{% set content %}
<div class="container mx-auto py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold">{{ page_title | e }}</h1>
        {% if auth_required %}
        <div class="flex items-center space-x-4">
            <span class="text-sm text-gray-600">User: <?php echo htmlspecialchars($_SESSION['user_name'] ?? 'Guest'); ?></span>
        </div>
        {% endif %}
    </div>
    
    <!-- Feedback -->
    <?php if ($error): ?><div class="bg-gray-100 border border-gray-400 text-red-700 p-4 rounded mb-4"><?php echo htmlspecialchars($error); ?></div><?php endif; ?>
    <?php if ($message): ?><div class="bg-gray-100 border border-gray-400 text-green-700 p-4 rounded mb-4"><?php echo htmlspecialchars($message); ?></div><?php endif; ?>

    <!-- 
      TODO: Implement UI for {{ page_name }}
    -->
    <div class="border border-gray-200 rounded p-8">
        <p class="text-gray-500">Content for {{ page_name }} goes here.</p>
    </div>
</div>
{% endset %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title | e }}</title>
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Tailwind CSS -->
    <?php if (getenv('APP_ENV') === 'prod'): ?>
        <link rel="stylesheet" href="/style.css">
    <?php else: ?>
        <script src="https://cdn.tailwindcss.com"></script>
    <?php endif; ?>
</head>
<body class="bg-white font-sans text-gray-900">
    <nav class="border-b border-gray-200 px-6 py-4 mb-8">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="text-xl font-bold">MyApp</a>
            <div class="flex items-center space-x-4">
                <a href="/" class="hover:underline">Home</a>
                {% if auth_required %}
                <a href="/logout.php" class="text-sm hover:underline">Logout</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-6">
        <?php echo $content; ?>
    </main>
</body>
</html>
